default_platform(:ios)

platform :ios do

  desc "Build and test the DesignSystem package. Omit arguments to use the default destination, or pass destination: '...' to override."
  lane :test do |options|
    destination = options[:destination] || "platform=iOS Simulator,name=iPhone 17 Pro"
    run_tests(
      package_path: ".",
      scheme: "DesignSystem",
      destination: destination,
      result_bundle: true
    )
  end

  desc "Build and upload the Demo app to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]
    increment_build_number(xcodeproj: "Demo/DesignSystemDemo.xcodeproj")
    build_app(
      scheme: "DesignSystemDemo",
      project: "Demo/DesignSystemDemo.xcodeproj",
      export_method: "app-store"
    )
    upload_to_testflight(groups: ["Internal Testers"])
  end

end
